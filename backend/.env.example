# --- SmartThings OAuth2 (app DEDICATA al backend, separata da quella del Pi) ---
# Scope necessari sull'app: r:devices:*  x:devices:*   (x = esecuzione comandi)
ST_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ST_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ST_REDIRECT_URI=https://httpbin.org/get
ST_SCOPES=r:devices:* x:devices:*
ST_TOKEN_STORE=token_store_backend.json
DEVICE_IDS=device-id-1,device-id-2

# --- InfluxDB (SOLA LETTURA) ---
INFLUX_URL=https://<region>.aws.cloud2.influxdata.com
INFLUX_ORG=la-tua-org
INFLUX_BUCKET=casa_sensori
INFLUX_TOKEN=token-di-sola-lettura

# --- Sicurezza app -> backend ---
# Chiave condivisa tra app Android e backend (header X-API-Key). Genera un valore lungo e casuale.
APP_API_KEY=genera-una-chiave-lunga-e-casuale

# --- Tuya / Smart Life (prese smart) — opzionale ---
# Region Europe: https://openapi.tuyaeu.com  (lascia vuoti gli ID per disabilitare)
TUYA_ENDPOINT=https://openapi.tuyaeu.com
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=

# --- Pi-hole (via tailnet) — opzionale ---
# Il Raspberry con Pi-hole deve essere in Tailscale; metti il suo IP/nome tailnet (con http://).
PIHOLE_URL=
PIHOLE_PASSWORD=

# --- Night mode ---
NIGHTMODE_CONFIG=nightmode_config.json
